# Copy this file to .env.local and fill in your EmailJS credentials.
# Create a free account at https://www.emailjs.com to get these values.
# See DEPLOYMENT.md for full setup instructions.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Email address that receives contact form submissions (used in the EmailJS template).
VITE_CONTACT_EMAIL=info@karvicare.com.au
